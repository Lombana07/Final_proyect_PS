<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Facturas - FacturaX</title>
    <link rel="stylesheet" href="/css/dashboard.css">
    <link rel="stylesheet" href="/css/invoice.css">
</head>
<body>
    <%- include('partials/sidebar') %>

    <main>
        <div class="header">
            <h2>Gestión de Facturas</h2>
            <button class="btn-primary" onclick="openModal()">+ Nueva Factura</button>
        </div>

        <!-- TABLA 1: FACTURAS ACTIVAS -->
        <div class="stat-card">
            <h3>Facturas Activas (Emitidas)</h3>
            <table class="data-table">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Cliente</th>
                        <th>Total</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    <% activeInvoices.forEach(inv => { %>
                    <tr>
                        <td>#<%= inv.id %></td>
                        <td><%= inv.Customer ? inv.Customer.name : 'N/A' %></td>
                        <td>$<%= inv.total.toLocaleString() %></td>
                        <td>
                            <!-- Solo el ADMIN puede anular según tu requerimiento -->
                            <button class="btn-delete" onclick="annulInvoice('<%= inv.id %>')">Anular</button>
                        </td>
                    </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>

        <br><br>

        <!-- TABLA 2: FACTURAS ANULADAS -->
        <div class="stat-card" style="opacity: 0.8;">
            <h3 style="color: var(--text-muted);">Historial de Facturas Anuladas</h3>
            <table class="data-table">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Cliente</th>
                        <th>Total</th>
                        <th>Estado</th>
                    </tr>
                </thead>
                <tbody>
                    <% annulledInvoices.forEach(inv => { %>
                    <tr>
                        <td>#<%= inv.id %></td>
                        <td><%= inv.Customer ? inv.Customer.name : 'N/A' %></td>
                        <td>$<%= inv.total.toLocaleString() %></td>
                        <td>
                            <span class="status-badge status-cancelled">ANULADA</span>
                        </td>
                    </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </main>
    <!-- MODAL PARA CREAR FACTURA -->
    <div id="invoiceModal" class="modal">
        <div class="modal-content">
            <h3>Generar Nueva Factura</h3>
            <hr class="divider">
            
            <!-- Selección de Cliente -->
            <div class="form-group">
                <label>Cliente</label>
                <select id="customerId" class="form-control-dark">
                    <% customers.forEach(c => { %>
                        <option value="<%= c.id %>"><%= c.name %> (<%= c.documentNumber %>)</option>
                    <% }) %>
                </select>
            </div>

            <!-- Selector de Productos -->
            <h4 class="section-title">Agregar Productos</h4>
            <div class="item-row">
                <div style="flex: 2;">
                    <label class="label-small">Producto</label>
                    <select id="tempProduct" class="form-control-dark">
                        <% products.forEach(p => { %>
                            <option value="<%= p.id %>" data-price="<%= p.price %>" data-name="<%= p.name %>">
                                <%= p.name %> - $<%= p.price %>
                            </option>
                        <% }) %>
                    </select>
                </div>
                <div style="flex: 1;">
                    <label class="label-small">Cantidad</label>
                    <input type="number" id="tempQty" value="1" min="1" class="form-control-dark">
                </div>
                <button type="button" class="btn-primary" onclick="addItem()">Agregar</button>
            </div>

            <!-- Tabla Temporal de Ítems -->
            <table class="data-table" id="itemsTable">
                <thead>
                    <tr>
                        <th>Producto</th>
                        <th>Cant.</th>
                        <th>Precio</th>
                        <th>Subtotal</th>
                    </tr>
                </thead>
                <tbody id="itemsBody"></tbody>
            </table>

            <!-- Resumen de Totales -->
            <div class="invoice-totals">
                <p>Subtotal: <span id="lblSubtotal">$0</span></p>
                <p>IVA: <span id="lblTax">$0</span></p>
                <h3 class="total-highlight">Total: <span id="lblTotal">$0</span></h3>
            </div>

            <!-- Acciones del Modal -->
            <div class="modal-actions">
                <button class="btn-primary" onclick="saveInvoice()" style="flex: 2;">Emitir Factura</button>
                <button class="btn-delete-full" onclick="closeModal()" style="flex: 1;">Cancelar</button>
            </div>
        </div>
    </div>

    <script>
        let selectedItems = [];

        function openModal() { document.getElementById('invoiceModal').style.display = 'flex'; }
        
        function closeModal() { 
            document.getElementById('invoiceModal').style.display = 'none'; 
            selectedItems = [];
            renderItems();
        }

        function addItem() {
            const select = document.getElementById('tempProduct');
            const product = select.options[select.selectedIndex];
            const qty = parseInt(document.getElementById('tempQty').value);

            selectedItems.push({
                productId: product.value,
                name: product.dataset.name,
                price: parseFloat(product.dataset.price),
                quantity: qty
            });
            renderItems();
        }

        function renderItems() {
            const body = document.getElementById('itemsBody');
            body.innerHTML = '';
            let sub = 0;
            selectedItems.forEach(item => {
                const lineTotal = item.price * item.quantity;
                sub += lineTotal;
                body.innerHTML += `<tr><td>${item.name}</td><td>${item.quantity}</td><td>$${item.price}</td><td>$${lineTotal}</td></tr>`;
            });
            
            document.getElementById('lblSubtotal').innerText = '$' + sub.toLocaleString();
            document.getElementById('lblTotal').innerText = '$' + (sub * 1.19).toLocaleString() + ' (aprox)';
        }

        async function saveInvoice() {
            const data = {
                customerId: document.getElementById('customerId').value,
                items: selectedItems.map(i => ({ productId: i.productId, quantity: i.quantity }))
            };

            const res = await fetch('/api/invoices', {
                method: 'POST',
                headers: { 
                    'Content-Type': 'application/json',
                    'Authorization': 'Bearer ' + localStorage.getItem('token')
                },
                body: JSON.stringify(data)
            });

            if(res.ok) location.reload();
            else alert('Error al crear factura');
        }

        async function annulInvoice(id) {
            if(!confirm('¿Seguro que desea anular esta factura?')) return;
            const res = await fetch(`/api/invoices/${id}`, {
                method: 'DELETE', 
                headers: { 'Authorization': 'Bearer ' + localStorage.getItem('token') }
            });
            if(res.ok) location.reload();
        }
    </script>
</body>
</html>