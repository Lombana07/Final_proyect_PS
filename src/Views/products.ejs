<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Productos - FacturaX</title>
    <link rel="stylesheet" href="/css/dashboard.css">
    <style>
        .section-header { margin: 40px 0 20px; color: var(--text-muted); display: flex; align-items: center; gap: 10px; }
        .section-header hr { flex: 1; border: 0; border-top: 1px solid var(--border); }
        .table-inactive { opacity: 0.7; }
        .status-pill { padding: 2px 8px; border-radius: 4px; font-size: 0.7rem; font-weight: bold; }
        .status-active { background: rgba(13, 110, 253, 0.2); color: #0d6efd; border: 1px solid #0d6efd; }
        .status-disabled { background: rgba(220, 53, 69, 0.2); color: #dc3545; border: 1px solid #dc3545; }
    </style>
</head>
<body>
    <%- include('partials/sidebar') %>

    <main>
        <div class="header">
            <h2>Gestión de Productos</h2>
            <button class="btn-primary" onclick="openModal()">+ Nuevo Producto</button>
        </div>

        <!-- TABLA 1: PRODUCTOS ACTIVOS -->
        <div class="stat-card">
            <h3>Productos Disponibles</h3>
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Nombre</th>
                        <th>Precio Unitario</th>
                        <th>IVA (%)</th>
                        <th>Estado</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    <% activeProducts.forEach(p => { %>
                    <tr>
                        <td><%= p.name %></td>
                        <td>$<%= parseFloat(p.price).toLocaleString() %></td>
                        <td><%= p.taxPercentage %>%</td>
                        <td><span class="status-pill status-active">ACTIVO</span></td>
                        <td>
                            <button class="btn-edit" onclick="editProduct('<%= p.id %>')">Editar</button>
                            <button class="btn-delete" onclick="disableProduct('<%= p.id %>')">Desactivar</button>
                        </td>
                    </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>

        <!-- SEPARADOR Y TABLA 2: PRODUCTOS INHABILITADOS -->
        <div class="section-header">
            <h4>Historial de Productos Desactivados</h4>
            <hr>
        </div>

        <div class="stat-card table-inactive">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Nombre</th>
                        <th>Último Precio</th>
                        <th>IVA</th>
                        <th>Estado</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    <% inactiveProducts.forEach(p => { %>
                    <tr>
                        <td><%= p.name %></td>
                        <td>$<%= parseFloat(p.price).toLocaleString() %></td>
                        <td><%= p.taxPercentage %>%</td>
                        <td><span class="status-pill status-disabled">INACTIVO</span></td>
                        <td>
                            <!-- Solo el ADMIN puede reactivar -->
                            <button class="btn-primary" onclick="activateProduct('<%= p.id %>')">Reactivar</button>
                        </td>
                    </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </main>

    <script>
        // Función para desactivar (Lógica de desactivación lógica [2])
        async function disableProduct(id) {
            if(!confirm('¿Seguro que desea desactivar este producto? Ya no aparecerá en la creación de facturas.')) return;
            const res = await fetch(`/api/products/${id}`, {
                method: 'DELETE',
                headers: { 'Authorization': 'Bearer ' + localStorage.getItem('token') }
            });
            if(res.ok) location.reload();
            else alert('Error al desactivar el producto');
        }

        // Función para reactivar (Llama a la nueva ruta PUT)
        async function activateProduct(id) {
            if(!confirm('¿Desea reactivar este producto para la venta?')) return;
            const res = await fetch(`/api/products/${id}/activate`, {
                method: 'PUT',
                headers: { 'Authorization': 'Bearer ' + localStorage.getItem('token') }
            });
            if(res.ok) location.reload();
            else alert('Error al reactivar el producto');
        }
    </script>
</body>
</html>