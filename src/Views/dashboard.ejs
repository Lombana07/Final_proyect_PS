<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard — FacturaX</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,300&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/dashboard.css">

</head>
<body>

    <%- include('partials/sidebar') %>

    <main class="main-content">

        <!-- ── Header ── -->
        <div class="page-header">
            <div class="page-header__left">
                <span class="page-header__greeting">Bienvenido de nuevo,</span>
                <h1 class="page-header__title">Dashboard</h1>
            </div>
            <div class="page-header__right">
                <div class="header-date">
                    <span class="header-date__icon">📅</span>
                    <span id="current-date"></span>
                </div>
                <div class="user-pill">
                    <div class="user-pill__avatar">A</div>
                    <span>Administrador</span>
                </div>
            </div>
        </div>

        <!-- ── KPI Cards ── -->
        <section class="kpi-grid">

            <div class="kpi-card kpi-card--green">
                <div class="kpi-card__header">
                    <span class="kpi-card__label">Facturas emitidas</span>
                    <span class="kpi-card__icon">🧾</span>
                </div>
                <div class="kpi-card__value">
                    $<%= totalSales ? Number(totalSales).toLocaleString('es-CO') : '0' %>
                </div>
                <div class="kpi-card__footer">
                    <span class="kpi-badge kpi-badge--up">↑ este mes</span>
                </div>
            </div>

            <div class="kpi-card kpi-card--blue">
                <div class="kpi-card__header">
                    <span class="kpi-card__label">Total ventas</span>
                    <span class="kpi-card__icon">💰</span>
                </div>
                <div class="kpi-card__value">
                    $<%= totalSales ? Number(totalSales).toLocaleString('es-CO') : '0' %>
                </div>
                <div class="kpi-card__footer">
                    <span class="kpi-card__sub">COP este mes</span>
                </div>
            </div>

            <div class="kpi-card kpi-card--amber">
                <div class="kpi-card__header">
                    <span class="kpi-card__label">IVA generado</span>
                    <span class="kpi-card__icon">📊</span>
                </div>
                <div class="kpi-card__value">
                    $<%= totalTax ? Number(totalTax).toLocaleString('es-CO') : '0' %>
                </div>
                <div class="kpi-card__footer">
                    <span class="kpi-badge kpi-badge--warn">pendiente declarar</span>
                </div>
            </div>

            <div class="kpi-card kpi-card--purple">
                <div class="kpi-card__header">
                    <span class="kpi-card__label">Clientes activos</span>
                    <span class="kpi-card__icon">👥</span>
                </div>
                <div class="kpi-card__value"><%= totalCustomers || 0 %></div>
                <div class="kpi-card__footer">
                    <span class="kpi-card__sub">registrados</span>
                </div>
            </div>

        </section>

        <!-- ── Main Grid ── -->
        <section class="dashboard-grid">

            <!-- Tabla de últimas facturas -->
            <div class="panel panel--wide">
                <div class="panel__head">
                    <div>
                        <h2 class="panel__title">Últimas facturas</h2>
                        <p class="panel__sub">Actividad reciente del sistema</p>
                    </div>
                    <a href="/facturas" class="btn-link">Ver todas →</a>
                </div>

                <div class="table-wrap">
                    <table class="invoice-table">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Cliente</th>
                                <th>Fecha</th>
                                <th>Estado</th>
                                <th class="text-right">Total</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% latestInvoices.forEach((invoice, i) => { %>
                            <tr class="invoice-row" style="animation-delay: <%= i * 100 %>ms">
                                <td>
                                    <span class="invoice-id">#<%= invoice.id %></span>
                                </td>
                                <td>
                                    <div class="client-cell">
                                        <div class="client-avatar">
                                            <%= invoice.Customer ? invoice.Customer.name.charAt(0).toUpperCase() : 'N' %>
                                        </div>
                                        <span> <%= invoice.Customer ? invoice.Customer.name : 'N/A' %></span>
                                    </div>
                                </td>
                                <td class="date-cell">
                                    <%= invoice.date ? new Date(invoice.date).toLocaleDateString('es-CO', { day: '2-digit', month: 'short', year: 'numeric' }) : '—' %>
                                </td>
                                <td>
                                    <% if (invoice.status === 'pagada') { %>
                                        <span class="status-pill status-pill--paid">● Pagada</span>
                                    <% } else if (invoice.status === 'pendiente') { %>
                                        <span class="status-pill status-pill--pending">● Pendiente</span>
                                    <% } else { %>
                                        <span class="status-pill status-pill--default">● Emitida</span>
                                    <% } %>
                                </td>
                                <td class="text-right amount-cell">
                                    $<%= Number(invoice.total).toLocaleString('es-CO') %>
                                </td>
                            </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- Resumen IVA -->
            <div class="panel">
                <div class="panel__head">
                    <div>
                        <h2 class="panel__title">Resumen IVA</h2>
                        <p class="panel__sub">Distribución del período</p>
                    </div>
                </div>
                <div class="iva-summary">
                    <div class="iva-row">
                        <div class="iva-row__label">
                            <span class="iva-dot iva-dot--blue"></span>
                            Base gravable
                        </div>
                        <div class="iva-row__bar">
                            <div class="iva-bar-fill" style="width:85%; background: #4f8ef7"></div>
                        </div>
                        <div class="iva-row__val">$<%= totalSales ? Number(totalSales).toLocaleString('es-CO') : 0 %></div>
                    </div>
                    <div class="iva-row">
                        <div class="iva-row__label">
                            <span class="iva-dot iva-dot--amber"></span>
                            IVA 19%
                        </div>
                        <div class="iva-row__bar">
                            <div class="iva-bar-fill" style="width:16%; background: #f59e0b"></div>
                        </div>
                        <div class="iva-row__val">$<%= totalTax ? Number(totalTax).toLocaleString('es-CO') : 0 %></div>
                    </div>
                    <div class="iva-row">
                        <div class="iva-row__label">
                            <span class="iva-dot iva-dot--green"></span>
                            Total facturado
                        </div>
                        <div class="iva-row__bar">
                            <div class="iva-bar-fill" style="width:100%; background: #34d399"></div>
                        </div>
                        <div class="iva-row__val">$<%= (totalSales && totalTax) ? Number(totalSales + totalTax).toLocaleString('es-CO') : 0 %></div>
                    </div>
                </div>

                <div class="iva-alert">
                    <span class="iva-alert__icon">⚠️</span>
                    <span>IVA pendiente de declarar ante la DIAN</span>
                </div>
            </div>

        </section>
    </main>

    <script>
        document.getElementById('current-date').textContent =
            new Date().toLocaleDateString('es-CO', { weekday: 'long', day: 'numeric', month: 'long', year: 'numeric' });
    </script>

</body>
</html>
