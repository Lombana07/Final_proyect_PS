<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Clientes - FacturaX</title>
    <link rel="stylesheet" href="/css/dashboard.css">
    <style>
        .section-header { margin: 40px 0 20px; color: var(--text-muted); display: flex; align-items: center; gap: 10px; }
        .section-header hr { flex: 1; border: 0; border-top: 1px solid var(--border); }
        .table-inactive { opacity: 0.7; }
        .status-pill { padding: 2px 8px; border-radius: 4px; font-size: 0.7rem; font-weight: bold; }
        .status-active { background: rgba(13, 110, 253, 0.2); color: #0d6efd; border: 1px solid #0d6efd; }
        .status-disabled { background: rgba(220, 53, 69, 0.2); color: #dc3545; border: 1px solid #dc3545; }
    </style>
</head>
<body>
    <%- include('partials/sidebar') %> <!-- [3] -->

    <main>
        <div class="header">
            <h2>Gestión de Clientes</h2>
            <button class="btn-primary" onclick="openModal()">+ Nuevo Cliente</button>
        </div>

        <!-- TABLA 1: CLIENTES ACTIVOS -->
        <div class="stat-card"> <!-- [4] -->
            <h3>Clientes Activos</h3>
            <table class="data-table"> <!-- [5] -->
                <thead>
                    <tr>
                        <th>Nombre</th>
                        <th>Documento</th>
                        <th>Estado</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    <% activeCustomers.forEach(c => { %> <!-- [1] -->
                    <tr>
                        <td><%= c.name %></td>
                        <td><%= c.documentType %>: <%= c.documentNumber %></td>
                        <td><span class="status-pill status-active">ACTIVO</span></td>
                        <td>
                            <button class="btn-edit" onclick="editCustomer('<%= c.id %>')">Editar</button>
                            <button class="btn-delete" onclick="disableCustomer('<%= c.id %>')">Desactivar</button>
                        </td>
                    </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>

        <!-- SEPARADOR Y TABLA 2: CLIENTES INHABILITADOS -->
        <div class="section-header">
            <h4>Clientes Inhabilitados</h4>
            <hr>
        </div>

        <div class="stat-card table-inactive">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Nombre</th>
                        <th>Documento</th>
                        <th>Estado</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    <% inactiveCustomers.forEach(c => { %> <!-- [1] -->
                    <tr>
                        <td><%= c.name %></td>
                        <td><%= c.documentType %>: <%= c.documentNumber %></td>
                        <td><span class="status-pill status-disabled">INACTIVO</span></td>
                        <td>
                            <!-- Solo el ADMIN puede reactivar según requerimientos -->
                            <button class="btn-primary" onclick="activateCustomer('<%= c.id %>')">Reactivar</button>
                        </td>
                    </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </main>

    <script>
        // Función para desactivar (Llama a tu CustomerController.disable) [6]
        async function disableCustomer(id) {
            if(!confirm('¿Seguro que desea desactivar este cliente?')) return;
            const res = await fetch(`/api/customers/${id}`, {
                method: 'DELETE',
                headers: { 'Authorization': 'Bearer ' + localStorage.getItem('token') }
            });
            if(res.ok) location.reload();
            else alert('Error al desactivar');
        }

        // Nueva función para reactivar (Llama a la ruta PUT que creamos)
        async function activateCustomer(id) {
            if(!confirm('¿Desea reactivar este cliente para que pueda volver a ser facturado?')) return;
            const res = await fetch(`/api/customers/${id}/activate`, {
                method: 'PUT',
                headers: { 'Authorization': 'Bearer ' + localStorage.getItem('token') }
            });
            if(res.ok) location.reload();
            else alert('Error al reactivar cliente');
        }
    </script>
</body>
</html>